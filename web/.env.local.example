NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_TINKR_API_URL=http://localhost:8787
NEXT_PUBLIC_TINKR_APP_URL=http://localhost:3000
# Production: set this to the published tinkr extension ID. That exact ID is
# allowed to receive an automatic browser-session hand-off. Leave it blank for
# localhost unpacked-extension development; tinkr will ask for one explicit
# confirmation before connecting the local extension instead.
NEXT_PUBLIC_TINKR_EXTENSION_ID=

# Supabase auth (Dashboard → Authentication → Providers → Email):
# - Enable Email provider
# - Enable Email password and magic-link sign-in
# - Configure http://localhost:3000/auth/callback as an allowed redirect URL
# - Production: add https://<your-web-project>.vercel.app/auth/callback
#
# Docker local dev: use repo-root .env.docker.example instead — see docs/LOCAL.md
# Optional: link on /install page to latest GitHub release
NEXT_PUBLIC_TINKR_GITHUB_REPO=https://github.com/hatif03/tinkr/releases/latest
