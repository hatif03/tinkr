{
  "manifest_version": 3,
  "name": "tinkr",
  "version": "0.3.0",
  "description": "Remix live webpages without changing the original site.",
  "permissions": ["storage", "unlimitedStorage", "activeTab", "tabs", "sidePanel", "scripting", "downloads", "alarms"],
  "host_permissions": [
    "http://localhost:8787/*",
    "http://localhost:3000/*",
    "https://api.tinkr.com/*",
    "https://app.tinkr.com/*",
    "https://*.supabase.co/*"
  ],
  "externally_connectable": {
    "matches": ["http://localhost:3000/*", "https://app.tinkr.com/*"]
  },
  "action": { "default_title": "Open tinkr" },
  "icons": {
    "16": "assets/brand/tinkr-16.png",
    "32": "assets/brand/tinkr-32.png",
    "48": "assets/brand/tinkr-48.png",
    "128": "assets/brand/tinkr-128.png"
  },
  "side_panel": { "default_path": "sidepanel.html" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["http://*/*", "https://*/*"],
    "js": [
      "tinkr-config.js",
      "packages/canvas/icons.js",
      "packages/canvas/stroke-engine.js",
      "packages/canvas/tool-definitions.js",
      "packages/canvas/tool-controller.js",
      "packages/canvas/vector-engine.js",
      "packages/canvas/dev-inspect.js",
      "packages/canvas/patch-applicator.js",
      "content-toolbar.js",
      "content.js"
    ],
    "css": ["content.css"],
    "run_at": "document_idle"
  }],
  "sandbox": { "pages": ["sandbox.html"] },
  "content_security_policy": { "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval'; connect-src 'none'" },
  "web_accessible_resources": [{ "resources": ["sandbox.html", "sandbox.js"], "matches": ["http://*/*", "https://*/*"] }]
}
