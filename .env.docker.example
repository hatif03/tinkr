# Local Docker development environment.
# Copy to .env.docker before running: cp .env.docker.example .env.docker
#
# Supabase runs on the host via `supabase start`. Containers reach it through
# host.docker.internal. Browser-facing URLs stay on localhost.

# --- API (server container) ---
PORT=8787
HOST=0.0.0.0
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.k2think.ai/v1
OPENAI_MODEL=MBZUAI-IFM/K2-Think-v2
TINKR_AI_TIMEOUT_MS=25000

# Local Supabase (default keys from `supabase start`)
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

PUBLIC_APP_URL=http://localhost:3000
TINKR_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- Web (Next.js container; NEXT_PUBLIC_* are read by the browser) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
NEXT_PUBLIC_TINKR_API_URL=http://localhost:8787
NEXT_PUBLIC_TINKR_APP_URL=http://localhost:3000
NEXT_PUBLIC_TINKR_EXTENSION_ID=
NEXT_PUBLIC_TINKR_GITHUB_REPO=https://github.com/hatif03/tinkr/releases/latest
