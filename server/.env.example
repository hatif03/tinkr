OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.k2think.ai/v1
OPENAI_MODEL=MBZUAI-IFM/K2-Think-v2
# Per-request timeout for the OpenAI-compatible provider. Values are clamped
# to 1,000–120,000 ms and never returned with credentials.
TINKR_AI_TIMEOUT_MS=25000
PORT=8787
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Use the legacy anon JWT from Supabase Dashboard → Project Settings → API (required for RLS auth.uid()).
# Required only for public review lookups. Keep this server-only.
SUPABASE_SERVICE_ROLE_KEY=
PUBLIC_APP_URL=http://localhost:3000
TINKR_APP_URL=http://localhost:3000
# Comma-separated dashboard origins allowed to call this API (plus chrome-extension://*).
# Production example: https://tinkr-web.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Docker local dev: copy ../.env.docker.example to repo-root .env.docker and run
# node scripts/dev-docker.mjs — see docs/LOCAL.md
